      m_Calls: []
  m_text: "Dr\xFCcke den linken Stick nach VORNE (+im Kreis) und ziele auf den Boden,
    um dich zu teleportieren UND die Richtung zu bestimmen.\n\nErkunde den Raum:\n\nLINKS
    & RECHTS: Riesen-Controller erkl\xE4ren die restliche Steuerung.\n\nIN DER MITTE:
    Teststation zum Greifen und \xDCben mit Objekten.\n\nGEGEN\xDCBER: Der Startbildschirm,
    um das eigentliche Spiel zu starten.\n\nNavigiere dich durch den Raum und probiere
    alles aus. \nViel Spa\xDF!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2100000, guid: e73a58f6e2794ae7b1b7e50b7fb811b0, type: 2}
